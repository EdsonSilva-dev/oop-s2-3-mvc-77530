@model IEnumerable<VgcCollege.MVC.Areas.Admin.ViewModels.ExamResultIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Exam Results";
    var examOptions = ViewBag.ExamOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Exam Results</h1>
    <a asp-action="Create" class="btn btn-primary">Create Exam Result</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Exam</label>
                <select name="examId" class="form-select">
                    <option value="">-- All Exams --</option>
                    @foreach (var item in examOptions)
                    {
                        if (ViewBag.ExamId != null && ViewBag.ExamId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Exam</th>
                    <th>Course</th>
                    <th>Student</th>
                    <th>Score</th>
                    <th>Grade</th>
                    <th>Status</th>
                    <th>Recorded At</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var result in Model)
                {
                    <tr>
                        <td>@result.ExamTitle</td>
                        <td>@result.CourseName</td>
                        <td>
                            <strong>@result.StudentName</strong><br />
                            <small class="text-muted">@result.StudentNumber</small>
                        </td>
                        <td>
                            @{
                                var percentage = result.MaxScore == 0 ? 0 : Math.Round((result.Score / result.MaxScore) * 100, 2);
                            }

                            <div>@result.Score / @result.MaxScore</div>

                            @if (percentage >= 70)
                            {
                                <span class="badge bg-success">@percentage%</span>
                            }
                            else if (percentage >= 40)
                            {
                                <span class="badge bg-warning text-dark">@percentage%</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@percentage%</span>
                            }
                        </td>
                        <td>@result.Grade</td>
                        <td>
                            @if (result.ResultsReleased)
                            {
                                <span class="badge bg-success">Released</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Provisional</span>
                            }
                        </td>
                        <td>@result.RecordedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@result.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@result.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@result.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model IEnumerable<VgcCollege.MVC.Areas.Admin.ViewModels.ExamIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Exams";
    var courseOptions = ViewBag.CourseOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Exams</h1>
    <a asp-action="Create" class="btn btn-primary">Create Exam</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Course</label>
                <select name="courseId" class="form-select">
                    <option value="">-- All Courses --</option>
                    @foreach (var item in courseOptions)
                    {
                        if (ViewBag.CourseId != null && ViewBag.CourseId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Release Status</label>
                <select name="released" class="form-select">
                    <option value="">-- All --</option>
                    @if (ViewBag.Released != null && ViewBag.Released.ToString().ToLower() == "true")
                    {
                        <option value="true" selected>Released</option>
                    }
                    else
                    {
                        <option value="true">Released</option>
                    }

                    @if (ViewBag.Released != null && ViewBag.Released.ToString().ToLower() == "false")
                    {
                        <option value="false" selected>Provisional</option>
                    }
                    else
                    {
                        <option value="false">Provisional</option>
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Title</th>
                    <th>Exam Date</th>
                    <th>Max Score</th>
                    <th>Weight</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exam in Model)
                {
                    <tr>
                        <td>
                            <strong>@exam.CourseName</strong><br />
                            <small class="text-muted">@exam.CourseCode</small>
                        </td>
                        <td>@exam.Title</td>
                        <td>@exam.ExamDate.ToString("dd/MM/yyyy")</td>
                        <td>@exam.MaxScore</td>
                        <td>@(exam.Weight?.ToString("0.##") ?? "-")</td>
                        <td>
                            @if (exam.ResultsReleased)
                            {
                                <span class="badge bg-success">Released</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Provisional</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@exam.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@exam.Id" class="btn btn-sm btn-outline-warning">Edit</a>

                            <form asp-action="ToggleRelease" asp-route-id="@exam.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    @(exam.ResultsReleased ? "Set Provisional" : "Release")
                                </button>
                            </form>

                            <a asp-area="Admin" asp-controller="ExamResults" asp-action="Index" asp-route-examId="@exam.Id" class="btn btn-sm btn-outline-secondary">Results</a>
                            <a asp-action="Delete" asp-route-id="@exam.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "Student Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Student Details</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-area="Admin" asp-controller="Enrolments" asp-action="Index" asp-route-studentSearch="@Model.StudentNumber" class="btn btn-outline-primary">View Enrolments</a>
        <a asp-area="Admin" asp-controller="Attendance" asp-action="Index" asp-route-studentSearch="@Model.StudentNumber" class="btn btn-outline-primary">View Attendance</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Linked User Id</dt>
            <dd class="col-sm-9">@Model.ApplicationUserId</dd>

            <dt class="col-sm-3">Enrolments</dt>
            <dd class="col-sm-9">
                <span class="badge bg-info">@Model.Enrolments.Count</span>
            </dd>
        </dl>
    </div>
</div>

@if (Model.Enrolments.Any())
{
    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body">
            <h5>Current Enrolments</h5>
            <ul class="mb-0">
                @foreach (var enrolment in Model.Enrolments)
                {
                    <li>@enrolment.Course?.Name</li>
                }
            </ul>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
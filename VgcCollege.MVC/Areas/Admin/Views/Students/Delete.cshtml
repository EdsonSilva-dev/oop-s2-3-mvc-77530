@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>

<div class="alert alert-warning mt-3">
    Are you sure you want to delete this student profile?
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Enrolments linked</dt>
            <dd class="col-sm-9">@Model.Enrolments.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
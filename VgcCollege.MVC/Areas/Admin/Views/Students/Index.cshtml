@model IEnumerable<VgcCollege.MVC.Areas.Admin.ViewModels.StudentIndexViewModel>

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Students</h1>
    <div class="d-flex gap-2">
        <a asp-action="CreateUser" class="btn btn-primary">Create Student User + Profile</a>
        <a asp-action="Create" class="btn btn-outline-primary">Link Existing Student User</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Student Number</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Enrolments</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.StudentNumber</td>
                        <td>@student.FullName</td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>
                            <span class="badge bg-info">@student.TotalEnrolments</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@student.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model VgcCollege.Domain.Entities.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance";
}

<h1>Delete Attendance Record</h1>

<div class="alert alert-warning mt-3">
    Are you sure you want to delete this attendance record?
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.StudentProfile?.FullName</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.Course?.Name</dd>

            <dt class="col-sm-3">Session Date</dt>
            <dd class="col-sm-9">@Model.SessionDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Week Number</dt>
            <dd class="col-sm-9">@Model.WeekNumber</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@((Model.Present) ? "Present" : "Absent")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
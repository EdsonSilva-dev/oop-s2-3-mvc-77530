@model IEnumerable<VgcCollege.MVC.Areas.Admin.ViewModels.AttendanceIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Attendance";
    var courseOptions = ViewBag.CourseOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Attendance Records</h1>
    <a asp-action="Create" class="btn btn-primary">Create Attendance Record</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Student Search</label>
                <input type="text" name="studentSearch" value="@ViewBag.StudentSearch" class="form-control" placeholder="Name or student number" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Course</label>
                <select name="courseId" class="form-select">
                    <option value="">-- All Courses --</option>
                    @foreach (var item in courseOptions)
                    {
                        if (ViewBag.CourseId != null && ViewBag.CourseId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Presence</label>
                <select name="present" class="form-select">
                    <option value="">-- All --</option>
                    @if (ViewBag.Present != null && ViewBag.Present.ToString().ToLower() == "true")
                    {
                        <option value="true" selected>Present</option>
                    }
                    else
                    {
                        <option value="true">Present</option>
                    }

                    @if (ViewBag.Present != null && ViewBag.Present.ToString().ToLower() == "false")
                    {
                        <option value="false" selected>Absent</option>
                    }
                    else
                    {
                        <option value="false">Absent</option>
                    }
                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Go</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Session Date</th>
                    <th>Week</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>
                        <strong>@record.StudentName</strong><br />
                        <small class="text-muted">@record.StudentNumber</small>
                    </td>
                    <td>
                        <strong>@record.CourseName</strong><br />
                        <small class="text-muted">@record.CourseCode</small>
                    </td>
                    <td>@record.SessionDate.ToString("dd/MM/yyyy")</td>
                    <td>@record.WeekNumber</td>
                    <td>
                        @if (record.Present)
                        {
                            <span class="badge bg-success">Present</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Absent</span>
                        }
                    </td>
                    <td>@record.Notes</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@record.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@record.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@record.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@model VgcCollege.Domain.Entities.CourseEnrolment

@{
    ViewData["Title"] = "Enrolment Details";
}

<h1>Enrolment Details</h1>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.StudentProfile?.FullName (@Model.StudentProfile?.StudentNumber)</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course?.Name (@Model.Course?.Code)</dd>

            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Course?.Branch?.Name</dd>

            <dt class="col-sm-3">Enrolment Date</dt>
            <dd class="col-sm-9">@Model.EnrolDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Attendance Records</dt>
            <dd class="col-sm-9">@Model.AttendanceRecords.Count</dd>

            <dt class="col-sm-3">Assignment Results</dt>
            <dd class="col-sm-9">@Model.AssignmentResults.Count</dd>

            <dt class="col-sm-3">Exam Results</dt>
            <dd class="col-sm-9">@Model.ExamResults.Count</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
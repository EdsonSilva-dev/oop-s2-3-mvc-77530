@model VgcCollege.Domain.Entities.CourseEnrolment

@{
    ViewData["Title"] = "Delete Enrolment";
}

<h1>Delete Enrolment</h1>

<div class="alert alert-warning mt-3">
    Are you sure you want to delete this enrolment?
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.StudentProfile?.FullName</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course?.Name</dd>

            <dt class="col-sm-3">Enrolment Date</dt>
            <dd class="col-sm-9">@Model.EnrolDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
@model IEnumerable<VgcCollege.MVC.Areas.Admin.ViewModels.AssignmentIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Assignments";
    var courseOptions = ViewBag.CourseOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Assignments</h1>
    <a asp-action="Create" class="btn btn-primary">Create Assignment</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Course</label>
                <select name="courseId" class="form-select">
                    <option value="">-- All Courses --</option>
                    @foreach (var item in courseOptions)
                    {
                        if (ViewBag.CourseId != null && ViewBag.CourseId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Title</th>
                    <th>Max Score</th>
                    <th>Due Date</th>
                    <th>Weight</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assignment in Model)
                {
                    <tr>
                        <td>
                            <strong>@assignment.CourseName</strong><br />
                            <small class="text-muted">@assignment.CourseCode</small>
                        </td>
                        <td>@assignment.Title</td>
                        <td>@assignment.MaxScore</td>
                        <td>@assignment.DueDate.ToString("dd/MM/yyyy")</td>
                        <td>@(assignment.Weight?.ToString("0.##") ?? "-")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@assignment.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@assignment.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@assignment.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model VgcCollege.Domain.Entities.Assignment

@{
    ViewData["Title"] = "Assignment Details";
}

<h1>Assignment Details</h1>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course?.Name (@Model.Course?.Code)</dd>

            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Max Score</dt>
            <dd class="col-sm-9">@Model.MaxScore</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Weight</dt>
            <dd class="col-sm-9">@(Model.Weight?.ToString("0.##") ?? "-")</dd>

            <dt class="col-sm-3">Results Recorded</dt>
            <dd class="col-sm-9">@Model.Results.Count</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-area="Admin" asp-controller="AssignmentResults" asp-action="Index" asp-route-assignmentId="@Model.Id" class="btn btn-outline-primary">View Results</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
@model VgcCollege.Domain.Entities.AssignmentResult

@{
    ViewData["Title"] = "Assignment Result Details";
}

<h1>Assignment Result Details</h1>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Assignment</dt>
            <dd class="col-sm-9">@Model.Assignment?.Title</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Assignment?.Course?.Name</dd>

            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.CourseEnrolment?.StudentProfile?.FullName (@Model.CourseEnrolment?.StudentProfile?.StudentNumber)</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Model.Score / @Model.Assignment?.MaxScore</dd>

            <dt class="col-sm-3">Feedback</dt>
            <dd class="col-sm-9">@Model.Feedback</dd>

            <dt class="col-sm-3">Graded At</dt>
            <dd class="col-sm-9">@Model.GradedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
@model VgcCollege.Domain.Entities.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h1>Delete Course</h1>

<div class="alert alert-warning mt-3">
    Are you sure you want to delete this course?
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9">@Model.Code</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Branch?.Name</dd>

            <dt class="col-sm-3">Enrolments linked</dt>
            <dd class="col-sm-9">@Model.Enrolments.Count</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
@model VgcCollege.MVC.Areas.Student.ViewModels.StudentAttendanceIndexViewModel

@{
    ViewData["Title"] = "My Attendance";
}

<h1>My Attendance</h1>

@if (Model.Summaries.Any())
{
    <div class="row g-3 mt-1 mb-4">
        @foreach (var summary in Model.Summaries)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title">@summary.CourseName</h5>
                        <p class="text-muted mb-2">@summary.CourseCode</p>

                        <p class="mb-1">
                            <strong>Present:</strong> @summary.PresentCount / @summary.TotalSessions
                        </p>

                        <p class="mb-0">
                            <strong>Attendance:</strong>
                            @if (summary.AttendancePercentage >= 80)
                            {
                                <span class="badge bg-success">@summary.AttendancePercentage%</span>
                            }
                            else if (summary.AttendancePercentage >= 60)
                            {
                                <span class="badge bg-warning text-dark">@summary.AttendancePercentage%</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@summary.AttendancePercentage%</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Session Date</th>
                    <th>Week</th>
                    <th>Status</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Records)
                {
                    <tr>
                        <td>
                            <strong>@record.CourseName</strong><br />
                            <small class="text-muted">@record.CourseCode</small>
                        </td>
                        <td>@record.SessionDate.ToString("dd/MM/yyyy")</td>
                        <td>@record.WeekNumber</td>
                        <td>
                            @if (record.Present)
                            {
                                <span class="badge bg-success">Present</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Absent</span>
                            }
                        </td>
                        <td>@record.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
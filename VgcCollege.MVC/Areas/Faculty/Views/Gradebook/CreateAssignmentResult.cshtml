@model VgcCollege.MVC.Areas.Faculty.ViewModels.FacultyAssignmentResultCreateEditViewModel

@{
    ViewData["Title"] = "Create Assignment Result";
}

<h1>Create Assignment Result</h1>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body">
        <form asp-action="CreateAssignmentResult" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label"></label>
                <select asp-for="AssignmentId" asp-items="Model.Assignments" class="form-select">
                    <option value="">-- Select Assignment --</option>
                </select>
                <span asp-validation-for="AssignmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CourseEnrolmentId" class="form-label"></label>
                <select asp-for="CourseEnrolmentId" asp-items="Model.Enrolments" class="form-select">
                    <option value="">-- Select Enrolment --</option>
                </select>
                <span asp-validation-for="CourseEnrolmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Feedback" class="form-label"></label>
                <textarea asp-for="Feedback" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Assignments" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
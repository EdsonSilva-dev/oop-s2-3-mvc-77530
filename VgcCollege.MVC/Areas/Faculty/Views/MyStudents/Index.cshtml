@model IEnumerable<VgcCollege.MVC.Areas.Faculty.ViewModels.FacultyStudentIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "My Students";
    var courseOptions = ViewBag.CourseOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>My Students</h1>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Name or student number" />
            </div>

            <div class="col-md-5">
                <label class="form-label">Course</label>
                <select name="courseId" class="form-select">
                    <option value="">-- All My Courses --</option>
                    @foreach (var item in courseOptions)
                    {
                        if (ViewBag.CourseId != null && ViewBag.CourseId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>
                            <strong>@student.FullName</strong><br />
                            <small class="text-muted">@student.StudentNumber</small>
                        </td>
                        <td>
                            <strong>@student.CourseName</strong><br />
                            <small class="text-muted">@student.CourseCode</small>
                        </td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>@student.EnrolmentStatus</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@student.StudentProfileId" class="btn btn-sm btn-outline-info">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model IEnumerable<VgcCollege.MVC.Areas.Faculty.ViewModels.FacultyAttendanceIndexViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "My Attendance Tools";
    var courseOptions = ViewBag.CourseOptions as List<SelectListItem> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Attendance</h1>
    <a asp-action="Create" class="btn btn-primary">Create Attendance Record</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Name or student number" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Course</label>
                <select name="courseId" class="form-select">
                    <option value="">-- All My Courses --</option>
                    @foreach (var item in courseOptions)
                    {
                        if (ViewBag.CourseId != null && ViewBag.CourseId.ToString() == item.Value)
                        {
                            <option value="@item.Value" selected>@item.Text</option>
                        }
                        else
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Presence</label>
                <select name="present" class="form-select">
                    <option value="">-- All --</option>
                    <option value="true" selected="@(ViewBag.Present?.ToString() == "True")">Present</option>
                    <option value="false" selected="@(ViewBag.Present?.ToString() == "False")">Absent</option>
                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Go</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Date</th>
                    <th>Week</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.StudentName</strong><br />
                            <small class="text-muted">@item.StudentNumber</small>
                        </td>
                        <td>
                            <strong>@item.CourseName</strong><br />
                            <small class="text-muted">@item.CourseCode</small>
                        </td>
                        <td>@item.SessionDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.WeekNumber</td>
                        <td>
                            @if (item.Present)
                            {
                                <span class="badge bg-success">Present</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Absent</span>
                            }
                        </td>
                        <td>@item.Notes</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center p-5">
                <h1 class="text-danger mb-3">Something went wrong</h1>
                <p class="lead">
                    An unexpected error occurred while processing your request.
                </p>
                <p class="text-muted">
                    The issue has been logged. Please try again or return to the home page.
                </p>

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        Back to Home
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="RedirectByRole" class="btn btn-outline-secondary">
                        Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>